---
import Layout from '../layouts/Layout.astro'
import ServiceCard from '../components/ServiceCard.astro'
import PromoCarousel from '../components/PromoCarousel.jsx'
import { services } from '../data/services.js'
---

<Layout
  title="Аргумент — Экспертная организация в Новосибирске"
  description="Почерковедческая, техническая и судебная экспертиза документов. Экспертиза без посредников. Бесплатная консультация. Новосибирск."
>
  <div class="page-stack">
    <PromoCarousel client:load />
    <div class="feature-grid">
      {services.map((service) => (
        <ServiceCard service={service} />
      ))}
    </div>
  </div>
</Layout>
